{
    "name": "asnardd/lang-helper",
    "description": "A simple package for Laravel to help you create lang files easily with a simple artisan command.",
    "keywords": [
        "Asnardd",
        "laravel",
        "lang-helper",
        "translations",
        "artisan"
    ],
    "homepage": "https://github.com/asnardd/lang-helper",
    "license": "MIT",
    "authors": [
        {
            "name": "Asnard",
            "email": "titouan@asnard.fr",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0.0||^9.0.0||^8.22.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Asnardd\\LangHelper\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Asnardd\\LangHelper\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Asnardd\\LangHelper\\LangHelperServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
